class = "btn-download-corp"),
div(class = "hint-text",
style = "margin-top:10px;",
"💡 Exported Excel: Click any row's 🔗 link in Processed_Data sheet to jump to that row in Original_Data sheet.")
)
),
# ── MAIN CONTENT AREA ─────────────────────────────────
column(9,
uiOutput("stats_ui"),
uiOutput("status_msg"),
div(class = "panel",
div(class = "panel-title",
span(class = "icon", "📋"), "Cleaned Data Preview"),
DTOutput("data_table")
)
)
)
)
)
# ── Server ───────────────────────────────────────────────────────────────────
server <- function(input, output, session) {
result <- reactiveVal(NULL)
observeEvent(input$process_btn, {
req(input$file_input)
result(NULL)
tryCatch({
res <- process_sensor_data(
file_path     = input$file_input$datapath,
threshold_sec = input$threshold
)
result(res)
}, error = function(e) {
result(list(error = conditionMessage(e)))
})
})
# ── Summary stat cards ──
output$stats_ui <- renderUI({
res <- result()
if (is.null(res) || !is.null(res$error)) return(NULL)
d <- res$data
n_alarm   <- sum(grepl("alarm", tolower(d$`DDM Status`)))
n_warning <- sum(grepl("warning", tolower(d$`DDM Status`)))
tagList(
div(class = "section-label", "Summary"),
div(class = "stats-grid",
div(class = "stat-card blue",
div(class = "stat-card-label", "Final Rows"),
div(class = "stat-card-value", nrow(d)),
div(class = "stat-card-sub",   "After all filters")
),
div(class = "stat-card red",
div(class = "stat-card-label", "Alarms"),
div(class = "stat-card-value", n_alarm),
div(class = "stat-card-sub",   "DDM alarm events")
),
div(class = "stat-card orange",
div(class = "stat-card-label", "Warnings"),
div(class = "stat-card-value", n_warning),
div(class = "stat-card-sub",   "DDM warning events")
),
div(class = "stat-card gray",
div(class = "stat-card-label", "Rows Removed"),
div(class = "stat-card-value", res$rows_removed),
div(class = "stat-card-sub",
paste0("≤ ", input$threshold, "s threshold"))
)
)
)
})
# ── Status message ──
output$status_msg <- renderUI({
res <- result()
if (is.null(res)) return(NULL)
if (!is.null(res$error)) {
div(class = "alert-corp error",
span(class = "alert-icon", "✖"),
span(paste("Processing failed:", res$error))
)
} else {
div(class = "alert-corp success",
span(class = "alert-icon", "✔"),
span(sprintf(
"Processing complete — %d rows in final output. %d rows removed by threshold.",
nrow(res$data), res$rows_removed))
)
}
})
# ── Data table  (hide Orig_Row column in preview) ──
output$data_table <- renderDT({
res <- result()
if (is.null(res) || !is.null(res$error)) return(NULL)
preview_cols <- setdiff(names(res$data), "Orig_Row")
datatable(
res$data[, preview_cols, drop = FALSE],
options  = list(
pageLength    = 15,
scrollX       = TRUE,
dom           = "lfrtip",
language      = list(search = "Search:"),
stripeClasses = c("odd-row", "even-row")
),
rownames = FALSE,
class    = "stripe hover compact"
)
})
# ── Download  ──────────────────────────────────────────────────────────────
output$download_btn <- downloadHandler(
filename = function() {
paste0("sensor_log_output_", format(Sys.time(), "%Y%m%d_%H%M%S"), ".xlsx")
},
content = function(file) {
res <- result()
req(!is.null(res), is.null(res$error))
# --- Read original CSV ---
original_data <- read.csv(input$file_input$datapath,
header = FALSE,
fileEncoding = "latin1",
stringsAsFactors = FALSE)
processed_data <- res$data
# --- Build workbook ---
wb <- createWorkbook()
addWorksheet(wb, "Processed_Data")
addWorksheet(wb, "Original_Data")
# ── Write Original_Data ──
writeData(wb, sheet = "Original_Data", x = original_data,
startRow = 1, startCol = 1, rowNames = FALSE, colNames = TRUE)
# Style header row – Original
orig_header_style <- createStyle(
fontName = "Calibri", fontSize = 11, fontColour = "#FFFFFF",
fgFill = "#0056b3", halign = "CENTER", textDecoration = "bold",
border = "Bottom", borderColour = "#003a7a"
)
addStyle(wb, "Original_Data", orig_header_style,
rows = 1, cols = seq_len(ncol(original_data)), gridExpand = TRUE)
freezePane(wb, "Original_Data", firstRow = TRUE)
setColWidths(wb, "Original_Data", cols = seq_len(ncol(original_data)), widths = "auto")
# ── Red highlight for ALARM rows in Original_Data ──
orig_alarm_style <- createStyle(
fgFill = "#FFD6D6", fontColour = "#7B0000", textDecoration = "bold"
)
for (r in seq_len(nrow(processed_data))) {
ddm_status <- processed_data$`DDM Status`[r]
if (!is.na(ddm_status) && grepl("alarm", tolower(ddm_status))) {
orig_excel_row <- processed_data$Orig_Row[r] + 1
addStyle(wb, "Original_Data", orig_alarm_style,
rows       = orig_excel_row,
cols       = seq_len(ncol(original_data)),
gridExpand = TRUE, stack = TRUE)
}
}
# ── Processed_Data ──
data_cols   <- setdiff(names(processed_data), "Orig_Row")
export_data <- processed_data[, data_cols, drop = FALSE]
export_data[["View Source"]] <- "🔗 Go to row"
col_order <- c("Time And Date","EVENT","Device","Direction","View Source",
"DDM Status","DDM VALUE",
"SDM STATUS","SDM VALUE",
"AM INDEX STATUS","AM INDEX VALUE",
"FORWARD POWER STATUS","FORWARD POWER VALUE")
export_data <- export_data[, col_order, drop = FALSE]
writeData(wb, sheet = "Processed_Data", x = export_data,
startRow = 1, startCol = 1, rowNames = FALSE, colNames = TRUE)
# ── Inject hyperlinks into "View Source" column ──
link_col_idx <- which(names(export_data) == "View Source")
for (r in seq_len(nrow(processed_data))) {
orig_row_num     <- processed_data$Orig_Row[r]
target_excel_row <- orig_row_num + 1
target_cell      <- paste0("Original_Data!A", target_excel_row)
writeFormula(
wb,
sheet    = "Processed_Data",
x        = paste0('=HYPERLINK("#', target_cell, '","🔗 Go to row")'),
startRow = r + 1,
startCol = link_col_idx
)
}
# ── Styles: Processed_Data header ──
proc_header_style <- createStyle(
fontName = "Calibri", fontSize = 11, fontColour = "#FFFFFF",
fgFill = "#0056b3", halign = "CENTER", textDecoration = "bold",
border = "Bottom", borderColour = "#003a7a"
)
addStyle(wb, "Processed_Data", proc_header_style,
rows = 1, cols = seq_len(ncol(export_data)), gridExpand = TRUE)
# "View Source" column – hyperlink style
link_style <- createStyle(
fontName = "Calibri", fontSize = 10,
fontColour = "#0056b3", textDecoration = "underline",
halign = "CENTER"
)
addStyle(wb, "Processed_Data", link_style,
rows  = 2:(nrow(export_data) + 1),
cols  = link_col_idx,
gridExpand = TRUE)
# Alternating row shading (applied first, alarm overrides later)
even_style <- createStyle(fgFill = "#F8FAFC")
for (r in seq(2, nrow(export_data) + 1, by = 2)) {
addStyle(wb, "Processed_Data", even_style,
rows = r, cols = seq_len(ncol(export_data)), gridExpand = TRUE)
}
# ── Red highlight for ALARM rows in Processed_Data ──
alarm_style <- createStyle(
fgFill = "#FFD6D6", fontColour = "#7B0000", textDecoration = "bold"
)
for (r in seq_len(nrow(export_data))) {
ddm_status <- export_data$`DDM Status`[r]
if (!is.na(ddm_status) && grepl("alarm", tolower(ddm_status))) {
addStyle(wb, "Processed_Data", alarm_style,
rows       = r + 1,
cols       = seq_len(ncol(export_data)),
gridExpand = TRUE, stack = TRUE)
}
}
freezePane(wb, "Processed_Data", firstRow = TRUE)
setColWidths(wb, "Processed_Data",
cols   = seq_len(ncol(export_data)),
widths = "auto")
# ── Save ──
saveWorkbook(wb, file, overwrite = TRUE)
}
)
}
# ── Run ──────────────────────────────────────────────────────────────────────
shinyApp(ui = ui, server = server)
