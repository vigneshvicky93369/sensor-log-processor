column(3,
div(class = "section-label", "Configuration"),
div(class = "panel",
div(class = "panel-title",
span(class = "icon", "📂"), "Upload File"),
fileInput("file_input", "Select CSV File",
accept      = ".csv",
placeholder = "No file selected",
